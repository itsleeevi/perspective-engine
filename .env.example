# Perspective Engine — environment variables
# All keys below are UNUSED in Phase 1 (local skeleton, mocked adapters).
# Populate and rename to .env when wiring real providers in Phase 2+.

# LangSmith tracing (Phase 3+)
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=

# Script / quality-gate LLM (Phase 2+)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Image generation (Phase 2+)
FAL_KEY=

# Video generation via fal.ai router (Phase 2+)
# FAL_KEY is shared with image gen above

# Voice / TTS (Phase 2+)
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=   # optional; defaults to Rachel (21m00Tcm4TlvDq8ikWAM)

# Publishing (Phase 4+)
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=
